{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["sfo1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://fieldwire.vercel.app"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/signin",
      "destination": "/auth/sign-in-simple",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "/auth/sign-in-simple",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/dashboard",
      "permanent": true
    }
  ]
} 